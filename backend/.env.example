# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your local MongoDB URI or MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/job-tracker

# Authentication (JSON Web Token)
# Generate a secure random 64-byte hex string for production
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Google Gemini API (Used via OpenAI SDK compatibility layer)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Cross-Origin Resource Sharing (CORS)
# URL of your frontend application
CLIENT_URL=http://localhost:5173
